# ===========================================
# Database Configuration
# ===========================================
# Supported drivers: sqlite, mysql, d1
DB_DRIVER=sqlite

# ===========================================
# SQLite Configuration (Local Development)
# ===========================================
SQLITE_PATH=./data/app.db

# ===========================================
# MySQL Configuration (Production Server)
# ===========================================
# Uncomment and configure when using MySQL
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=biomimic_app

# ===========================================
# Cloudflare D1 Configuration
# ===========================================
# D1 is configured via wrangler.toml, not env vars
# The binding is automatically injected by Cloudflare Workers

# ===========================================
# Application Configuration
# ===========================================
# Mock Mode (development)
VITE_USE_MOCK_SERVER=true

# Server Port
PORT=3010
