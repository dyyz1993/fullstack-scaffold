{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "types": ["vitest/globals", "node"],
    "paths": {
      "@cli/*": ["src/cli/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/index.ts", "src/commands/**/*.ts", "src/generators/**/*.ts", "src/cli/**/*.ts", "src/__tests__/**/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "template"]
}
