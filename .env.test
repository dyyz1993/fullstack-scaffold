# ===========================================
# Test Environment Configuration
# ===========================================

# Database Configuration (use separate test database)
DB_DRIVER=sqlite
SQLITE_PATH=./data/test.db

# Server Port (for integration tests)
PORT=0

# API Documentation (disable in test)
ENABLE_DOCS=false

# Mock Mode
VITE_USE_MOCK_SERVER=true

# Browser Configuration (use Chromium for tests)
PLAYWRIGHT_TEST_BROWSER_TYPE=chromium
PLAYWRIGHT_TEST_BROWSER_EXECUTABLE_PATH=/Applications/Chromium.app/Contents/MacOS/Chromium
