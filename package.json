{
  "name": "create-biomimic-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit && eslint . --max-warnings=0",
    "typecheck:template": "cd template && npx tsc --noEmit",
    "lint": "eslint .",
    "lint:template": "cd template && npx eslint src/ --max-warnings=0",
    "test": "vitest run",
    "test:template": "cd template && npx vitest run",
    "test:watch": "vitest",
    "validate:template": "cd template && npm run validate:all",
    "validate:modules": "cd template && npm run validate:modules",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^9.39.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
