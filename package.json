{
  "name": "create-biomimic-app",
  "version": "1.0.0",
  "description": "Create a new BioMimic app with Todo List example",
  "type": "module",
  "bin": {
    "create-biomimic-app": "./src/index.ts"
  },
  "files": [
    "src",
    "template"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "prepublishOnly": "echo 'Ready to publish'",
    "test": "node --test src/**/*.test.ts",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "typecheck:template": "cd template && npm run typecheck",
    "lint:template": "cd template && npm run lint",
    "validate:template": "cd template && npm run validate:all",
    "test:template": "cd template && npm run test:smart:staged"
  },
  "keywords": [
    "create-app",
    "cli",
    "template",
    "biomimic",
    "react",
    "vite"
  ],
  "author": "BioMimic Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "clipboardy": "^4.0.0",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "template/src/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
